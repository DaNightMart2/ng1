{

    "namespace": "server_form",
    "$schema": "https://kalmemarq.github.io/Bugrock-JSON-UI-Schemas/ui.schema.json",

    "main_screen_content": {
        "type": "panel",
        "size": [0, 0],
        "controls": [
            {
                "server_form_factory": {
                    "type": "factory",
                    "control_ids": {
                        "long_form": "@server_form.dialogue_form",
                        "custom_form": "@server_form.custom_form"
                    }
                }
            }
        ]
    },

    "size_anim": {
        "anim_type": "size",
        "easing": "out_cubic",
        "from": [0, "25%"],
        "to": ["100%", "100%"],
        "duration": 0.5
    },

    "pos_anim": {
        "anim_type": "offset",
        "easing": "out_cubic",
        "from": ["-800px", 0],
        "to": [-245, 0],
        "duration": 0.5
    },

    "second_pos_anim": {
        "anim_type": "offset",
        "easing": "out_cubic",
        "from": [0, "200px"],
        "to": [0, 0],
        "duration": 1.0
    },

    "text_reveal_anim": {
        "anim_type": "size",
        "easing": "out_cubic",
        "from": [0, "100%"],
        "to": ["200%", "100%"],
        "duration": 3.0
    },

    "cancel_button_image": {
        "type": "image",
        "texture": "textures/ui/dialogue_box",
        "nineslice_size": [8, 8, 8, 8]
    },

    "option_label": {
        "type": "label",
        "font_size": "large",
        "text": "#form_button_text",
        "bindings": [
            {
                "binding_name": "#form_button_text",
                "binding_type": "collection",
                "binding_collection_name": "form_buttons"
            }
        ]
    },

    "character": {
        "type": "panel",
        "layer": 2,
        "controls": [
            {
                "face_image": {
                    "type": "image",
                    "size": ["50%", "50%"],
                    "offset": [0, -5],
                    "bindings": [
                        {
                            "binding_name": "#form_button_texture",
                            "binding_name_override": "#texture",
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons"
                        },
                        {
                            "binding_name": "#form_button_texture_file_system",
                            "binding_name_override": "#texture_file_system",
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons"
                        }
                    ]
                }
            },
            {
                "character_name": {
                    "type": "label",
                    "font_type": "default",
                    "font_size": "normal",
                    "offset": [0, 35],
                    "text": "#form_button_text",
                    "bindings": [
                        {
                            "binding_name": "#form_button_text",
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons"
                        }
                    ]
                }
            }
        ]
    },

    "options_panels": {
        "type": "panel",
        "controls": [
            {
                "first_option@server_form.single_option_panel": {
                    "offset": ["100px", "42%"],
                    "$index": 1
                }
            },
            {
                "second_option@server_form.single_option_panel": {
                    "offset": ["400px", "42%"],
                    "$index": 2
                }
            },
            {
                "third_option@server_form.single_option_panel": {
                    "offset": ["250px-25%c", "20%"],
                    "$index": 3
                }
            },
            {
                "fourth_option@server_form.single_option_panel": {
                    "offset": ["250px-25%c", "70%"],
                    "$index": 4
                }
            }
        ]
    },

    "single_option_panel": {
        "type": "stack_panel",
        "size": ["100%", "100%"],
        "orientation": "horizontal",
        "collection_name": "form_buttons",
        "controls": [
            {
                "single_button": {
                    "type": "button",
                    "collection_index": "$index",
                    "size": ["100%c", "100%c"],
                    "default_control": "default",
                    "focus_enabled": true,
                    "hover_control": "hover",
                    "bindings": [
                        {
                            "binding_type": "collection_details",
                            "binding_collection_name": "form_buttons"
                        }
                    ],
                    "button_mappings": [
                        {
                            "from_button_id": "button.menu_select",
                            "to_button_id": "button.form_button_click",
                            "mapping_type": "focused"
                        },
                        {
                            "from_button_id": "button.controller_select",
                            "to_button_id": "button.form_button_click",
                            "mapping_type": "focused"
                        },
                        {
                            "from_button_id": "button.menu_ok",
                            "to_button_id": "button.form_button_click",
                            "mapping_type": "focused"
                        }
                    ],
                    "controls": [
                        {
                            "default@server_form.option_label": {
                                "color": [1, 1, 1]
                            }
                        },
                        {
                            "hover@server_form.option_label": {
                                "color": [1, 1, 0]
                            }
                        }
                    ]
                }
            }
        ]
    },

    "dialogue_form": {
        "type": "panel",
        "offset": [0, "110px"],
        "size": ["600px", "120px"],
        "controls": [
            {
                "cancel_button@common_buttons.light_text_button": { 
                    "size": ["100%", "100%"],
                    "$pressed_button_name": "button.menu_exit",
                    "layer": 0,
                    "focus_enabled": false,
                    "controls": [
                        {
                            "animated_cancel_button_image@server_form.cancel_button_image": {
                                "anims": [
                                    "@server_form.size_anim"
                                ],
                                "bindings": [
                                    {
                                        "binding_name": "(#title_text = 'true')",
                                        "binding_name_override": "#visible"
                                    }
                                ]
                            }
                        },
                        {
                            "unanimated_cancel_button_image@server_form.cancel_button_image": {
                                "bindings": [
                                    {
                                        "binding_name": "(not(#title_text = 'true'))",
                                        "binding_name_override": "#visible"
                                    }
                                ]
                            }
                        }
                    ],
                    "button_mappings": [
                        {
                            "from_button_id": "button.menu_ok",
                            "to_button_id": "button.menu_exit",
                            "mapping_type": "global"
                        },
                        {
                            "from_button_id": "button.menu_select",
                            "to_button_id": "button.menu_exit",
                            "mapping_type": "global"
                        }
                    ]
                }
            },

            {
                "character": {
                    "type": "panel",
                    "controls": [
                        {
                            "character_animated@server_form.character": {
                                "anims": [
                                    "@server_form.pos_anim"
                                ],
                                "bindings": [
                                    {
                                        "binding_name": "(#title_text = 'true')",
                                        "binding_name_override": "#visible"
                                    }
                                ]
                            }
                        },
                        {
                            "character_unanimated@server_form.character": {
                                "offset": [-245, 0],
                                "bindings": [
                                    {
                                        "binding_name": "(not(#title_text = 'true'))",
                                        "binding_name_override": "#visible"
                                    }
                                ]
                            }
                        }
                    ]
                }
            },

            {
                "dialogue_text": {
                    "type": "panel",
                    "clips_children": true,
                    "offset": ["-50%c", 0],
                    "layer": 3,
                    "anims": [
                        "@server_form.text_reveal_anim"
                    ],
                    "controls": [
                        {
                            "dialogue_label": {
                                "type": "label",
                                "text": "#form_text",
                                "font_type": "default",
                                "font_size": "large",
                                "offset": ["50%x+35px", 0]
                            }
                        }
                    ]
                }
            },

            {
                "options_panel_control": {
                    "type": "panel",
                    "controls": [
                        {
                            "animated_options_panel@server_form.options_panels": {
                                "anims": [
                                    "@server_form.second_pos_anim"
                                ],
                                "bindings": [
                                    {
                                        "binding_name": "(#title_text = 'true')",
                                        "binding_name_override": "#visible"
                                    }
                                ]
                            }
                        },
                        {
                            "unanimated_options_panel@server_form.options_panels": {
                                "bindings": [
                                    {
                                        "binding_name": "(not(#title_text = 'true'))",
                                        "binding_name_override": "#visible"
                                    }
                                ]
                            }
                        }
                    ]
                }
            }
        ]
    }
}